function git_color() {
  local git_info="$(__git_ps1 "%s")"
  if [[ $git_info == *"%"* ]] || [[ $git_info == *"*"* ]]; then
    echo '%F{red}'
  elif [[ $git_info == *"+"* ]]; then
    echo '%F{yellow}'
  else
    echo '%F{#00ff82}'
  fi
}

function get_status() {
        local git_status="$(__git_ps1 "%s")"
        if [[ $git_status == "" ]] then
                :
        else
                echo "[$(git_color)$(__git_ps1 "%s")%f${fg[magenta]}]"
        fi
}
